    "### Gas Aggregation Functions\n",
    "\n",
    "To account for Injective's fast block times, we can test different strategies for aggregating gas usage over a window of blocks."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def agg_last_block(gas_history):\n",
    "    \"\"\"Baseline: Use the gas from the last block.\"\"\"\n",
    "    if not gas_history:\n",
    "        return 0\n",
    "    return gas_history[-1]\n",
    "\n",
    "def agg_moving_average(gas_history):\n",
    "    \"\"\"Use a simple moving average over the history window.\"\"\"\n",
    "    if not gas_history:\n",
    "        return 0\n",
    "    return sum(gas_history) / len(gas_history)"
   ]
